{
  "name": "deltadotta",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.4",
  "keywords": ["organization", "ai-agents", "skills", "cli", "claude-code", "codex"],
  "bin": {
    "deltadotta": "./dist/bin/deltadotta.js"
  },
  "files": ["dist", "README.md", "LICENSE", "NOTICE", "TRADEMARK.md"],
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "cli:build": "tsc -p tsconfig.cli.json",
    "cli": "pnpm cli:build && node dist/bin/deltadotta.js",
    "verify": "pnpm typecheck && pnpm cli:build && pnpm test && pnpm build",
    "prepack": "pnpm cli:build"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
